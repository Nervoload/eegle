{
  "runtime": {
    "project_name": "eegle",
    "session_root": "data",
    "runtime_cache_dir": ".runtime"
  },
  "telemetry": {
    "console_level": "default",
    "file_level": "realtime",
    "trace_enabled": false,
    "heartbeat_seconds": 5.0
  },
  "hardware": {
    "eeg": {
      "family": "Enobio",
      "profile": "enobio8_inhibition",
      "expected_channel_counts": [8],
      "expected_sample_rate_hz": 500,
      "lsl_stream_type": "EEG",
      "lsl_name_patterns": ["enobio", "nic", "neuroelectrics", "LSLOutletStreamName-EEG"],
      "allow_type_only_fallback": false,
      "stream_timeout_seconds": 5.0,
      "sample_probe_seconds": 2.0,
      "required_for_run": true
    },
    "markers": {
      "lsl_stream_name": "EEGleMarkers",
      "lsl_stream_type": "Markers",
      "required_for_realtime": true
    },
    "display": {
      "screen_index": 0,
      "full_screen": false,
      "win_type": "pyglet",
      "allow_gui": true,
      "size": [1000, 700],
      "units": "height",
      "background_color": "black",
      "photodiode_patch": false,
      "expected_refresh_rate_hz": 60.0,
      "fixed_display_latency_ms": 0.0
    }
  },
  "experiment": {
    "experiment_id": "go_nogo_eeg_condition_classifier",
    "participant_id": "example-participant",
    "task": "go_nogo",
    "mode": "forward",
    "components": {
      "preflight": "default",
      "task": "go_nogo",
      "eeg_recorder": "lsl_csv",
      "realtime_processor": "lsl",
      "feedback": "disabled",
      "analysis": "minimal"
    },
    "output_formats": ["csv", "jsonl", "triggers_txt", "raw_json"]
  },
  "processes": {
    "recorder": {
      "enabled": true,
      "backend": "lsl_csv",
      "csv_mirror": true,
      "startup_timeout_seconds": 8.0
    },
    "realtime_processor": {
      "enabled": true,
      "backend": "lsl",
      "preprocessor": "causal_bandpass_notch",
      "model": "erp_roi_logreg",
      "startup_timeout_seconds": 8.0
    },
    "feedback": {
      "enabled": false,
      "backend": "disabled"
    },
    "dashboard": {
      "enabled": false,
      "backend": "http",
      "host": "127.0.0.1",
      "port": 8765,
      "startup_timeout_seconds": 4.0
    },
    "offline_analyzer": {
      "enabled": true,
      "backend": "minimal",
      "timeout_seconds": 120.0
    }
  },
  "tasks": {
    "go_nogo": {
      "trials": 240,
      "go_probability": 0.7,
      "no_go_probability": 0.3,
      "stimulus_seconds": 0.8,
      "isi_seconds": 0.7,
      "practice_enabled": true,
      "practice_message_min_seconds": 1.0,
      "countdown_seconds": 3,
      "countdown_step_seconds": 1.0,
      "response_keys": ["space"],
      "escape_keys": ["escape"],
      "completion_auto_close_seconds": 30.0,
      "shapes": ["circle", "square", "triangle", "star", "hexagon"],
      "colors": ["red", "blue", "green", "yellow", "magenta"],
      "no_go": {
        "shape": "x",
        "color": "white",
        "randomize": false
      }
    }
  },
  "realtime": {
    "enabled": true,
    "max_chunk_samples": 32,
    "max_pull_samples": 128,
    "pull_timeout_seconds": 0.01,
    "clock_error_threshold_seconds": 60.0,
    "inference": {
      "enabled": false
    },
    "classifier": {
      "enabled": true
    },
    "capture": {
      "enabled": true
    },
    "dashboard": {
      "enabled": false,
      "host": "127.0.0.1",
      "port": 8765
    },
    "epoching": {
      "enabled": true,
      "marker_prefix": "go_nogo_stimulus_onset",
      "tmin_seconds": -0.2,
      "tmax_seconds": 0.8,
      "timebase": "lsl",
      "sample_tolerance_seconds": 0.01,
      "drop_incomplete": true,
      "include_practice_trials": false
    },
    "preprocessing": {
      "notch_hz": 60.0,
      "bandpass_low_hz": 1.0,
      "bandpass_high_hz": 45.0,
      "downsample_factor": 1,
      "reference": "average"
    },
    "quality_gate": {
      "minimum_finite_fraction": 1.0,
      "minimum_channel_std_uv": 0.01,
      "max_abs_uv": 250.0,
      "max_peak_to_peak_uv": 400.0
    },
    "model": {
      "kind": "erp_roi_logreg",
      "bundle_path": null,
      "artifact_path": null,
      "input_layout": "samples_x_channels",
      "input_units": "microvolts",
      "required_channels": ["Fz", "Cz", "Pz", "C3", "C4", "P3", "P4", "Oz"],
      "baseline_seconds": [-0.2, 0.0],
      "decision_probability": 0.5,
      "seed": 42
    },
    "shadow_models": [],
    "decision_policy": {
      "kind": "observe_only",
      "enabled": true,
      "allow_task_adaptation": false,
      "actions": ["observe_only"]
    },
    "feedback": {
      "mode": "observe_only",
      "allow_task_adaptation": false,
      "allow_stimulation": false,
      "client": {
        "enabled": false,
        "backend": "disabled"
      }
    },
    "alpha": {
      "enabled": false
    },
    "event_features": {
      "enabled": false
    }
  },
  "analysis": {
    "erp": {
      "enabled": true,
      "task": "go_nogo",
      "tmin_seconds": -0.2,
      "tmax_seconds": 0.8,
      "baseline_seconds": [-0.2, 0.0],
      "n2_window_seconds": [0.2, 0.35],
      "p300_window_seconds": [0.3, 0.6],
      "filter_low_hz": 0.1,
      "filter_high_hz": 30.0,
      "notch_hz": 60.0,
      "input_units": "microvolts",
      "roi_channels": ["Cz", "Pz", "P3", "P4"],
      "n2_roi_channels": ["Fz", "Cz"],
      "dashboard_montage_times_ms": [-200, 0, 100, 200, 300, 400, 500, 600, 700, 800],
      "dashboard_px_per_second": 220
    },
    "alpha": {
      "enabled": false
    },
    "html": {
      "enabled": true,
      "max_raw_points": 120000,
      "max_alpha_points": 12000
    },
    "reports": {
      "behavior": true,
      "raw_eeg_summary": true
    }
  }
}
