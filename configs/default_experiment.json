{
  "runtime": {
    "project_name": "eegle",
    "session_root": "data",
    "runtime_cache_dir": ".runtime"
  },
  "telemetry": {
    "console_level": "default",
    "file_level": "realtime",
    "trace_enabled": false,
    "heartbeat_seconds": 5.0
  },
  "hardware": {
    "eeg": {
      "family": "Enobio",
      "profile": "enobio32",
      "expected_channel_counts": [8, 22, 32],
      "expected_sample_rate_hz": 500,
      "lsl_stream_type": "EEG",
      "lsl_name_patterns": ["enobio", "nic", "neuroelectrics"],
      "stream_timeout_seconds": 5.0,
      "sample_probe_seconds": 2.0,
      "required_for_run": false
    },
    "markers": {
      "lsl_stream_name": "EEGleMarkers",
      "lsl_stream_type": "Markers"
    },
    "display": {
      "screen_index": 0,
      "full_screen": false,
      "win_type": "pyglet",
      "allow_gui": true,
      "units": "height",
      "background_color": "black",
      "photodiode_patch": false
    }
  },
  "experiment": {
    "experiment_id": "attention_working_memory_reproduction",
    "participant_id": "example-participant",
    "task": "pvt",
    "mode": "forward",
    "calibration_suite": null,
    "components": {
      "preflight": "default",
      "task": "pvt",
      "eeg_recorder": "lsl_csv",
      "realtime_processor": "disabled",
      "feedback": "disabled",
      "analysis": "minimal"
    },
    "output_formats": ["csv", "jsonl", "triggers_txt"],
    "procedures": [
      "preflight",
      "task",
      "realtime_optional",
      "post_analysis"
    ]
  },
  "processes": {
    "recorder": {
      "enabled": true,
      "backend": "lsl_csv",
      "csv_mirror": true,
      "startup_timeout_seconds": 8.0
    },
    "realtime_processor": {
      "enabled": false,
      "backend": "disabled",
      "preprocessor": "causal_bandpass_notch",
      "model": "erp_peak_baseline",
      "startup_timeout_seconds": 8.0
    },
    "feedback": {
      "enabled": false,
      "backend": "disabled"
    },
    "offline_analyzer": {
      "enabled": true,
      "backend": "minimal",
      "timeout_seconds": 120.0
    }
  },
  "tasks": {
    "pvt": {
      "trials": 20,
      "fixation_seconds": 1.0,
      "foreperiod_min_seconds": 2.0,
      "foreperiod_max_seconds": 10.0,
      "response_deadline_seconds": 2.0,
      "minimum_valid_rt_seconds": 0.1,
      "instruction_required": true,
      "completion_auto_close_seconds": 30.0,
      "target_radius": 0.09,
      "feedback_seconds": 0.5,
      "response_keys": ["space"],
      "escape_keys": ["escape"]
    },
    "go_nogo": {
      "trials": 40,
      "go_probability": 0.7,
      "no_go_probability": 0.3,
      "stimulus_seconds": 0.8,
      "isi_seconds": 0.7,
      "response_keys": ["space"],
      "escape_keys": ["escape"],
      "completion_auto_close_seconds": 30.0,
      "shapes": ["circle", "square", "triangle", "star", "hexagon"],
      "colors": ["red", "blue", "green", "yellow", "magenta"],
      "no_go": {
        "shape": "x",
        "color": "white",
        "randomize": false
      }
    },
    "n_back": {
      "n": 2,
      "blocks": 3,
      "trials_per_block": 40,
      "stimulus_seconds": 0.5,
      "isi_seconds": 2.0,
      "target_probability": 0.25
    },
    "sternberg": {
      "set_sizes": [2, 4, 6],
      "probe_seconds": 2.0,
      "retention_seconds": 3.0,
      "trials_per_set_size": 30
    },
    "anti_vea": {
      "blocks": 4,
      "trials_per_block": 80,
      "attention_conditions": ["valid", "invalid", "neutral"],
      "vigilance_targets": true
    }
  },
  "calibration": {
    "posterior_alpha": {
      "eyes_open_seconds": 120.0,
      "eyes_closed_seconds": 120.0,
      "go_nogo_practice_seconds": 150.0,
      "go_nogo_practice_trials": 100,
      "countdown_seconds": 5,
      "channel_protocol": ["P3", "P4", "PO3", "PO4", "Pz", "O1", "O2", "Oz"],
      "posterior_channels": ["P3", "P4", "PO3", "PO4", "Pz", "O1", "O2", "Oz"],
      "welch_window_seconds": 4.0,
      "welch_overlap_fraction": 0.5,
      "specparam_fit_range_hz": [3.0, 35.0],
      "specparam_peak_width_limits_hz": [0.5, 8.0],
      "specparam_max_n_peaks": 6,
      "specparam_min_peak_height": 0.05,
      "alpha_candidate_range_hz": [7.0, 14.0],
      "min_peak_power": 0.05,
      "min_bandwidth_hz": 0.5,
      "max_bandwidth_hz": 8.0,
      "min_eyes_closed_open_ratio": 1.05,
      "offline_max_abs_uv": 150.0,
      "offline_epoch_peak_to_peak_uv": 250.0,
      "online_window_seconds": 1.0,
      "online_step_seconds": 0.1,
      "online_smoothing_seconds": 0.2,
      "online_artifact_gate": {
        "max_abs_uv": 150.0,
        "max_peak_to_peak_uv": 250.0,
        "max_nan_fraction": 0.0
      },
      "synthetic_phase_seconds": 20.0
    }
  },
  "realtime": {
    "enabled": false,
    "window_seconds": 2.0,
    "step_seconds": 0.25,
    "performance": {
      "primary_latency_budget_ms": 50,
      "writer_flush_every": 50,
      "writer_flush_interval_ms": 100,
      "inference_queue_max_epochs": 4,
      "skip_shadows_when_queue_depth_gte": 2,
      "large_cap_channel_threshold": 32
    },
    "epoching": {
      "enabled": true,
      "marker_prefix": "go_nogo_stimulus_onset",
      "tmin_seconds": -0.2,
      "tmax_seconds": 0.8,
      "timebase": "lsl",
      "sample_tolerance_seconds": 0.01,
      "drop_incomplete": true,
      "include_practice_trials": false
    },
    "preprocessing": {
      "notch_hz": 60.0,
      "bandpass_low_hz": 1.0,
      "bandpass_high_hz": 45.0,
      "downsample_factor": 1,
      "reference": "average"
    },
    "model": {
      "kind": "erp_peak_baseline",
      "artifact_path": null,
      "input_layout": "samples_x_channels",
      "preprocessing": {
        "kind": "raw_epoch"
      },
      "required_channels": ["Pz", "Cz", "P3", "P4"],
      "roi_channels": ["Pz", "Cz", "CPz", "P3", "P4"],
      "baseline_seconds": [-0.2, 0.0],
      "p300_window_seconds": [0.25, 0.6],
      "input_units": "microvolts",
      "amplitude_threshold_uv": 3.0,
      "amplitude_slope_uv": 2.0,
      "decision_probability": 0.6
    },
    "decision_policy": {
      "kind": "conservative_p300",
      "enabled": true,
      "allow_task_adaptation": true,
      "probability_threshold": 0.6,
      "lower_probability_threshold": 0.4,
      "no_go_probability_step": 0.05,
      "isi_step_seconds": 0.05,
      "visual_alpha_value": 0.85,
      "actions": ["increase_no_go_probability", "adjust_isi", "set_visual_alpha", "show_reward", "repeat_condition", "observe_only"],
      "bounds": {
        "no_go_probability": [0.15, 0.45],
        "isi_seconds": [0.5, 1.25],
        "visual_alpha": [0.5, 1.0]
      },
      "cooldowns": {
        "trials": 2
      }
    },
    "feedback": {
      "mode": "visual_adaptation",
      "lsl_stream_name": "EEGleFeedback",
      "allow_task_adaptation": true,
      "allow_stimulation": false,
      "client": {
        "enabled": false,
        "backend": "auto",
        "lsl_stream_name": "EEGleFeedback",
        "jsonl_path": null
      }
    },
    "alpha": {
      "enabled": false,
      "method": "hilbert",
      "band": {
        "low_hz": 8.0,
        "high_hz": 12.0,
        "center_hz": 10.0,
        "bandwidth_hz": 4.0,
        "source": "default",
        "confidence": "fallback"
      },
      "posterior_channels": ["P3", "P4", "PO3", "PO4", "Pz", "O1", "O2", "Oz"],
      "window_seconds": 1.0,
      "step_seconds": 0.1,
      "smoothing_seconds": 0.2,
      "artifact_gate": {
        "max_abs_uv": 150.0,
        "max_peak_to_peak_uv": 250.0,
        "max_nan_fraction": 0.0
      }
    }
  },
  "analysis": {
    "erp": {
      "enabled": true,
      "task": "go_nogo",
      "tmin_seconds": -0.2,
      "tmax_seconds": 0.8,
      "baseline_seconds": [-0.2, 0.0],
      "p300_window_seconds": [0.25, 0.6],
      "filter_low_hz": 0.1,
      "filter_high_hz": 30.0,
      "notch_hz": 60.0,
      "input_units": "microvolts",
      "roi_channels": ["Pz", "Cz", "CPz", "P3", "P4"],
      "dashboard_montage_times_ms": [-200, 0, 100, 200, 300, 400, 500, 600, 700, 800],
      "dashboard_px_per_second": 220
    },
    "power_bands": {
      "delta": [1.0, 4.0],
      "theta": [4.0, 7.0],
      "alpha": [8.0, 12.0],
      "beta": [13.0, 30.0],
      "gamma": [30.0, 45.0]
    },
    "reports": {
      "behavior": true,
      "power_bands": true,
      "classification": true,
      "scalp_maps": true,
      "bids_export": false,
      "mne_report": true
    },
    "alpha": {
      "enabled": true
    },
    "html": {
      "enabled": true,
      "max_raw_points": 120000,
      "max_alpha_points": 12000
    }
  }
}
